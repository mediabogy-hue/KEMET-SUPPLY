{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the system, which can be a Dropshipper or an Admin-level role.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "Email address of the user, used for login.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The role of the user, defining their permissions.",
          "enum": [
            "Dropshipper",
            "Admin",
            "OrdersManager",
            "FinanceManager",
            "Merchant"
          ]
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "isActive": {
          "type": "boolean"
        },
        "initialPasswordChangeRequired": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "email",
        "role",
        "createdAt",
        "updatedAt",
        "isActive"
      ]
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Represents a product listed on the platform.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "merchantId": { "type": "string", "description": "The ID of the Merchant who owns this product." },
        "approvalStatus": {
            "type": "string",
            "description": "The approval status of the product.",
            "enum": ["Pending", "Approved", "Rejected"]
        }
      }
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "description": "Represents a customer order.",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "dropshipperId": { "type": "string" },
        "merchantId": { "type": "string" }
      }
    },
    "Wallet": {
      "title": "Wallet",
      "type": "object",
      "description": "Represents a user's financial wallet.",
      "properties": {
        "id": { "type": "string" },
        "availableBalance": { "type": "number" },
        "pendingBalance": { "type": "number" },
        "pendingWithdrawals": { "type": "number" },
        "totalWithdrawn": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "WithdrawalRequest": {
      "title": "Withdrawal Request",
      "type": "object",
      "description": "Represents a user's request to withdraw funds.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string", "enum": ["Vodafone Cash", "InstaPay", "Bank Transfer", "Telda"] },
        "paymentIdentifier": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Completed", "Rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "email"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      },
      "description": "Stores product details."
    },
    "/orders/{orderId}": {
      "schema": {
        "$ref": "#/entities/Order"
      },
      "description": "Stores order details."
    },
    "/wallets/{userId}": {
      "schema": {
        "$ref": "#/entities/Wallet"
      },
      "description": "Stores user wallet data."
    },
    "/users/{userId}/withdrawalRequests/{reqId}": {
      "schema": {
        "$ref": "#/entities/WithdrawalRequest"
      },
      "description": "Stores a user's withdrawal requests."
    },
    "/adminWithdrawalRequests/{reqId}": {
      "schema": {
        "$ref": "#/entities/WithdrawalRequest"
      },
      "description": "A collection for admins to manage all withdrawal requests."
    }
  }
}
