
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function getRole(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }
    
    function isRole(role) {
       return isSignedIn() && getRole(request.auth.uid) == role;
    }

    function isStaff() {
       return isSignedIn() && (getRole(request.auth.uid) in ['Admin', 'OrdersManager', 'FinanceManager', 'ProductManager']);
    }
    
    function isAdmin() {
       return isRole('Admin');
    }

    // --------------------------------
    // Collection Rules
    // --------------------------------

    // USERS
    match /users/{userId} {
      // Anyone can create their own user document during sign-up
      allow create: if isSignedIn();
      allow get: if isSignedIn();
      allow update: if isOwner(userId) || isAdmin();
      allow list, delete: if isAdmin();
      
      // USER SUBCOLLECTIONS (Owned by the user, only they and admins can access)
      match /bonuses/{bonusId} {
        allow read: if isOwner(userId) || isStaff();
        allow create, update, delete: if isStaff();
      }
      match /workSessions/{sessionId} {
        allow read, write: if isOwner(userId) || isStaff();
      }
    }
    
    // ORDERS (Global)
    match /orders/{orderId} {
      allow read: if isStaff() || isOwner(resource.data.dropshipperId);
      allow create: if isOwner(request.resource.data.dropshipperId) || isStaff();
      allow update: if isStaff() || isOwner(resource.data.dropshipperId);
      allow delete: if isAdmin();
    }
    
    // WITHDRAWAL REQUESTS (Global)
    match /withdrawalRequests/{requestId} {
       allow read: if isStaff() || isOwner(resource.data.userId);
       allow create: if isOwner(request.resource.data.userId);
       allow list, update, delete: if isStaff();
    }
    
    // PAYMENTS (Global)
    match /payments/{paymentId} {
      allow read: if isStaff() || isOwner(resource.data.dropshipperId);
      allow create: if isOwner(request.resource.data.dropshipperId);
      allow list, update, delete: if isStaff();
    }
    
    // PRODUCTS
    match /products/{productId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isStaff();

       match /clicks/{clickId} {
        allow create: if true; 
        allow read, list, write: if isStaff();
      }
    }

    // PUBLIC & ADMIN-ONLY COLLECTIONS
    match /productCategories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }
    match /shipments/{shipmentId} {
        allow read, write: if isStaff();
        match /events/{eventId} {
            allow read, write: if isStaff();
        }
    }
    match /stockLedger/{ledgerId} {
      allow read, write: if isStaff();
    }
    match /paymentMethods/{methodId} {
        allow read: if isSignedIn();
        allow write: if isStaff();
    }
    match /publicSettings/data {
        allow read: if true;
        allow write: if isAdmin();
    }
    match /systemSettings/{settingId} {
        allow read, write: if isAdmin();
    }
    match /auditLogs/{logId} {
        allow read, write: if isAdmin();
    }
     match /merchantInquiries/{inquiryId} {
      allow create: if true;
      allow read, list, update, delete: if isStaff();
    }
    match /conversations/{conversationId} {
      function isParticipant() {
        return request.auth.uid in resource.data.participantIds;
      }
      allow read, update: if isParticipant();
      allow create: if request.auth.uid in request.resource.data.participantIds;
    }
    match /conversations/{conversationId}/messages/{messageId} {
      function isParentConversationParticipant() {
        return request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
      allow read, create: if isParentConversationParticipant();
      allow update, delete: if false;
    }
    
    // This collection is used only to generate unique IDs client-side.
    // No one should be able to read or write to it directly.
    match /id_generator/{any} {
      allow read, write: if false;
    }
    
    // ROLES - Deprecated in favor of user document role checks. Kept for legacy compatibility if needed.
    // Consider deleting if no longer used.
    match /roles_admin/{userId} { allow read, write: if isAdmin(); }
    match /roles_product_manager/{userId} { allow read, write: if isAdmin(); }
    match /roles_orders_manager/{userId} { allow read, write: if isAdmin(); }
    match /roles_finance_manager/{userId} { allow read, write: if isAdmin(); }

  }
}

    