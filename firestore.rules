
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole(request.auth.uid) == 'Admin';
    }
    
    function isStaff() {
       return isSignedIn() && getUserRole(request.auth.uid) in ['Admin', 'OrdersManager', 'FinanceManager', 'ProductManager'];
    }

    // --------------------------------
    // Collection Rules
    // --------------------------------

    // USERS: 
    // - Anyone can create their own user document (needed for sign-up).
    // - Owner can read/update their own profile.
    // - Admin can read/list/write any profile.
    match /users/{userId} {
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow get, update: if isOwner(userId);
      allow list, write: if isAdmin();
      
      // USER SUBCOLLECTIONS (Owned by the user)
      match /orders/{orderId} {
        allow read, write: if isOwner(userId);
      }
      match /payments/{paymentId} {
         allow read, write: if isOwner(userId);
      }
      match /withdrawalRequests/{requestId} {
         allow read, write: if isOwner(userId);
      }
      match /bonuses/{bonusId} {
        allow read, write: if isOwner(userId);
      }
      match /workSessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // COLLECTION GROUP QUERIES:
    // Only staff can perform collection group queries across all users.
    match /{path=**}/orders/{orderId} { 
      allow list, get: if isStaff(); 
    }
    match /{path=**}/withdrawalRequests/{requestId} {
      allow list, get: if isStaff();
    }
     match /{path=**}/payments/{paymentId} {
      allow list, get: if isStaff();
    }
    match /{path=**}/workSessions/{sessionId} {
      allow list, get: if isStaff();
    }

    // PRODUCTS
    // - Publicly readable
    // - Any signed-in user can create a product (for merchants)
    // - Only owner can update/delete
    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.dropshipperId == request.auth.uid;
      allow update, delete: if isSignedIn() && get(/databases/$(database)/documents/products/$(productId)).data.dropshipperId == request.auth.uid;

       match /clicks/{clickId} {
        allow create: if true; // Public click tracking
        allow read, write: if isAdmin() || isProductManager();
      }
    }
    
    // PUBLIC & ADMIN-ONLY COLLECTIONS
    match /productCategories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isProductManager();
    }
    match /shipments/{shipmentId} {
        allow read, write: if isStaff();
        match /events/{eventId} {
            allow read, write: if isStaff();
        }
    }
    match /stockLedger/{ledgerId} {
      allow read, write: if isStaff();
    }
    match /paymentMethods/{methodId} {
        allow read: if isSignedIn();
        allow write: if isStaff();
    }
    match /publicSettings/data {
        allow read: if true;
        allow write: if isAdmin();
    }
    match /systemSettings/{settingId} {
        allow read, write: if isAdmin();
    }
    match /auditLogs/{logId} {
        allow read, write: if isAdmin();
    }
     match /merchantInquiries/{inquiryId} {
      allow create: if true;
      allow read, list, update, delete: if isStaff();
    }
    match /conversations/{conversationId} {
      function isParticipant() {
        return request.auth.uid in resource.data.participantIds;
      }
      allow read, update: if isParticipant();
      allow create: if request.auth.uid in request.resource.data.participantIds;
    }
    match /conversations/{conversationId}/messages/{messageId} {
      function isParentConversationParticipant() {
        return request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
      allow read, create: if isParentConversationParticipant();
      allow update, delete: if false;
    }
  }
}
